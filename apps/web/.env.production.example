# CallscraperCRM — Production env vars
# Paste real values into Vercel Dashboard > Project Settings > Environment Variables
# (or use: vercel env add <NAME> production)

# --- CRM Supabase (the CRM's own database) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-CRM-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME
SUPABASE_PROJECT_REF=YOUR-CRM-PROJECT

# --- Callscraper.com Supabase (upstream source data) ---
CALLSCRAPER_SUPABASE_URL=https://YOUR-CALLSCRAPER-PROJECT.supabase.co
CALLSCRAPER_SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME
CALLSCRAPER_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXX
CALLSCRAPER_SUPABASE_SERVICE_KEY=eyJhbGciOi...REPLACE_ME
CALLSCRAPER_SUPABASE_SECRET=sb_secret_XXXXXXXXXXXX

# --- Anthropic (optional; required if AI agent features are used) ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- Signing secrets (generate fresh for production; do NOT reuse dev) ---
# Generate with:  openssl rand -hex 32
BRIDGE_SIGNING_SECRET=REPLACE_WITH_RANDOM_HEX_32
ESTIMATE_SIGNING_SECRET=REPLACE_WITH_RANDOM_HEX_32

# --- Embed config (optional) ---
# Comma-separated list of parent origins allowed to embed the dashboard
NEXT_PUBLIC_EMBED_PARENT_ORIGINS=https://callscraper.com,https://www.callscraper.com
