# CallscraperCRM — production environment variables
# Copy these into Vercel Project Settings → Environment Variables

# --- CRM Supabase project (kxhqxrmroreuglvsatkn) ---
NEXT_PUBLIC_SUPABASE_URL=https://kxhqxrmroreuglvsatkn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstream callscraper.com Supabase project (earddtfueyboluglwbgt) ---
# Used by /api/sync/callscraper cron and any callscraper.ts consumers.
CALLSCRAPER_SUPABASE_URL=https://earddtfueyboluglwbgt.supabase.co
CALLSCRAPER_SUPABASE_SERVICE_KEY=

# --- CallScraper REST API (optional, when available) ---
# The REST API is not yet built on callscraper.com.
# When launched, set these to enable the REST adapter alongside direct Supabase sync.
# Per-workspace keys can also be stored via Settings → Integrations → API Keys.
CALLSCRAPER_BASE_URL=https://callscraper.com
CALLSCRAPER_API_KEY=

# --- Anthropic (optional global fallback) ---
# Per-workspace keys are preferred via Settings → Integrations → API Keys.
# This is only used when a workspace has not configured its own key.
ANTHROPIC_API_KEY=
