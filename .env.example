# CallscraperCRM — environment template.
# Copy to `.env.local` for dev, or /etc/callscraper/env.production on the VPS.
# Never commit real values. .env.local is gitignored.

# ─── CRM Supabase (target of all estimator writes) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://kxhqxrmroreuglvsatkn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Allow anon-key fallback for local dev only. Never set in prod.
# ALLOW_ANON_CRM_CLIENT=true

# ─── CallScraper v3 Supabase (realtime call_summaries source) ─────────
CALLSCRAPER_SUPABASE_URL=https://earddtfueyboluglwbgt.supabase.co
CALLSCRAPER_SUPABASE_KEY=
# Legacy alias still honored for backward compat:
CALLSCRAPER_SUPABASE_SERVICE_KEY=

# Subscriber-side persistence of sync_state cursor.
CRM_SUPABASE_URL=https://kxhqxrmroreuglvsatkn.supabase.co
CRM_SUPABASE_KEY=

# ─── CRM subscriber → webhook ─────────────────────────────────────────
# Where the subscriber POSTs normalized call payloads.
CRM_WEBHOOK_URL=https://<crm-domain>/api/webhooks/callscraper
# Shared HMAC secret between subscriber and webhook. Generate: `openssl rand -hex 32`
CALLSCRAPER_WEBHOOK_SECRET=

# ─── SmartMoving Premium API ──────────────────────────────────────────
# One credential set per brand today; split into _APM/_AFM if they diverge.
SMARTMOVING_API_KEY=
SMARTMOVING_PROVIDER_KEY=
SMARTMOVING_CLIENT_ID=

# ─── Anthropic (transcript extraction + driveway vision) ──────────────
ANTHROPIC_API_KEY=

# ─── Google Maps (Distance Matrix + StreetView) ───────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Legacy callscraper.com REST fallback (optional) ──────────────────
CALLSCRAPER_BASE_URL=https://callscraper.com
CALLSCRAPER_API_KEY=

# ─── Historical scrape runtime (pass when invoking sm-historical-sync) ─
# ORG_ID=00000000-0000-0000-0000-000000000001
# BRAND_CODE=APM
# LIMIT_PER_CATEGORY=1000
